{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "es2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@budget-now/contract": ["../../packages/contracts/index.ts"]
    }
  },
  "include": ["src"]
}
